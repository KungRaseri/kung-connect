# ── KungConnect environment template ─────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=kungconnect
POSTGRES_USER=kungconnect
POSTGRES_PASSWORD=changeme_strong_password

# ── Server ───────────────────────────────────────────────────────────────────
KUNGCONNECT_CONNECTION_STRING=Host=db;Port=5432;Database=kungconnect;Username=kungconnect;Password=changeme_strong_password
KUNGCONNECT_JWT_SECRET=change_me_to_a_256_bit_secret_key_here__32chars!!
KUNGCONNECT_JWT_ISSUER=KungConnect
KUNGCONNECT_JWT_AUDIENCE=KungConnect

# Deployment mode: SingleTenant | MultiTenant
KUNGCONNECT_SERVER_MODE=SingleTenant
KUNGCONNECT_ALLOW_SELF_REGISTRATION=true

# ── Optional TURN relay ───────────────────────────────────────────────────────
RELAY_ENABLED=false
RELAY_TURN_SERVER_URL=turn:your-coturn-host:3478
RELAY_TURN_USERNAME=kungconnect
RELAY_TURN_PASSWORD=changeme
# RELAY_TURN_SHARED_SECRET=your_hmac_secret  # for time-limited credentials

# ── Optional Redis (for multi-instance signaling scale-out) ──────────────────
REDIS_ENABLED=false
REDIS_CONNECTION_STRING=localhost:6379

# ── Agent ─────────────────────────────────────────────────────────────────────
KUNGCONNECT_AGENT_SERVER_URL=http://localhost:5000
KUNGCONNECT_AGENT_ALIAS=MyMachine
KUNGCONNECT_AGENT_SECRET=changeme_machine_secret
KUNGCONNECT_AGENT_AUTO_ACCEPT=false
