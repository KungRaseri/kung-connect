# .env.example — copy to .env and adjust values before running docker compose.
#
#   cp .env.example .env
#   docker compose up -d
#
# The defaults below work out of the box for LOCAL DEVELOPMENT.
# Change anything marked [CHANGE IN PRODUCTION] before deploying.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=kungconnect
POSTGRES_USER=kungconnect
POSTGRES_PASSWORD=devpassword123                  # [CHANGE IN PRODUCTION]

# ── Server ────────────────────────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above
KUNGCONNECT_CONNECTION_STRING=Host=db;Port=5432;Database=kungconnect;Username=kungconnect;Password=devpassword123

# JWT signing secret — must be ≥32 characters             [CHANGE IN PRODUCTION]
KUNGCONNECT_JWT_SECRET=dev_only_secret_key_change_me_in_prod_xxxxxxxxxx

KUNGCONNECT_JWT_ISSUER=KungConnect
KUNGCONNECT_JWT_AUDIENCE=KungConnect

# SingleTenant | MultiTenant
KUNGCONNECT_SERVER_MODE=SingleTenant
KUNGCONNECT_ALLOW_SELF_REGISTRATION=true

# Port the server listens on externally (container always uses 5000 internally)
SERVER_PORT=5000

# ── Agent (only needed when running: docker compose --profile agent up) ───────
AGENT_ALIAS=DockerAgent
AGENT_SECRET=dev_agent_secret_change_me          # [CHANGE IN PRODUCTION]
AGENT_AUTO_ACCEPT=false

# ── Optional: TURN relay (docker compose --profile relay up) ─────────────────
RELAY_ENABLED=false
RELAY_TURN_SERVER_URL=turn:your-coturn-host:3478
RELAY_TURN_USERNAME=kungconnect
RELAY_TURN_PASSWORD=changeme
RELAY_TURN_SHARED_SECRET=changeme                # [CHANGE IN PRODUCTION]

# ── Optional: Redis for multi-instance SignalR scale-out ─────────────────────
REDIS_ENABLED=false
REDIS_CONNECTION_STRING=redis:6379

# ── Client downloads ─────────────────────────────────────────────────────────
# Override to point to your own build artifacts. Defaults to GitHub releases/latest.
DOWNLOADS_WINDOWS_URL=https://github.com/KungRaseri/kung-connect/releases/latest/download/KungConnect-win-x64.zip
DOWNLOADS_MACOS_URL=https://github.com/KungRaseri/kung-connect/releases/latest/download/KungConnect-osx-arm64.zip
DOWNLOADS_LINUX_URL=https://github.com/KungRaseri/kung-connect/releases/latest/download/KungConnect-linux-x64.tar.gz

# ── Agent downloads ───────────────────────────────────────────────────────────
# Override to point to your own build artifacts. Defaults to GitHub releases/latest.
DOWNLOADS_AGENT_WINDOWS_URL=https://github.com/KungRaseri/kung-connect/releases/latest/download/KungConnect-Agent-win-x64.zip
DOWNLOADS_AGENT_MACOS_URL=https://github.com/KungRaseri/kung-connect/releases/latest/download/KungConnect-Agent-osx-arm64.zip
DOWNLOADS_AGENT_LINUX_URL=https://github.com/KungRaseri/kung-connect/releases/latest/download/KungConnect-Agent-linux-x64.tar.gz
DOWNLOADS_AGENT_LINUX_ARM64_URL=https://github.com/KungRaseri/kung-connect/releases/latest/download/KungConnect-Agent-linux-arm64.tar.gz
