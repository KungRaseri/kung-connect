<?xml version="1.0" encoding="utf-8"?>
<!--
  productbuild distribution XML for KungConnect Agent.
  Drives the macOS Installer.app experience.
-->
<installer-gui-script minSpecVersion="1">
    <title>KungConnect Agent</title>

    <!-- Require macOS 12 (Monterey) or later -->
    <os-version min="12.0" />

    <options customize="never" require-scripts="true" />

    <pkg-ref id="com.kungconnect.agent" />

    <choices-outline>
        <line choice="default" />
    </choices-outline>

    <choice id="default" visible="false" selected="true" enabled="false">
        <pkg-ref id="com.kungconnect.agent" />
    </choice>

    <pkg-ref id="com.kungconnect.agent">component.pkg</pkg-ref>

</installer-gui-script>
