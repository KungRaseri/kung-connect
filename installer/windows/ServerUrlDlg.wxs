<?xml version="1.0" encoding="UTF-8"?>
<!--
  KungConnect Agent installer — Server URL dialog + custom UI sequence.

  Dialog flow:  WelcomeDlg → ServerUrlDlg → VerifyReadyDlg → (install) → ExitDialog

  The Next button on ServerUrlDlg is disabled until the user enters a non-empty URL
  that doesn't equal the placeholder "https://".
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!-- ── ServerUrlDlg dialog ───────────────────────────────────────────────── -->
  <Fragment>
    <UI>
      <Dialog Id="ServerUrlDlg" Width="370" Height="270" Title="[ProductName] Setup">

        <!-- Standard installer banner -->
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="!(wix.WixUIBannerBmp)" />
        <Control Id="BannerLine"  Type="Line" X="0" Y="44"  Width="370" Height="0" />
        <Control Id="BottomLine"  Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15"
                 Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Title}Server Configuration" />
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15"
                 Transparent="yes" NoPrefix="yes">
          <Text Value="Enter the address of your KungConnect server." />
        </Control>

        <!-- URL input -->
        <Control Id="ServerUrlLabel" Type="Text" X="25" Y="88" Width="320" Height="15">
          <Text Value="Server &amp;URL:" />
        </Control>
        <Control Id="ServerUrlEdit" Type="Edit" X="25" Y="105" Width="320" Height="18"
                 Property="SERVERURL" Text="{256}" />
        <Control Id="ServerUrlHint" Type="Text" X="25" Y="128" Width="320" Height="15">
          <Text Value="Example: https://my-server.example.com" />
        </Control>

        <!-- Navigation buttons -->
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17"
                 Text="!(loc.WixUI_ButtonText_Back)">
          <Publish Event="NewDialog" Value="WelcomeDlg" Condition="1" />
        </Control>

        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="!(loc.WixUI_ButtonText_Next)">
          <!-- WiX v4: Control/Condition children removed; use conditional Publish instead.
               The dialog only advances when the user has entered a non-placeholder URL. -->
          <Publish Event="NewDialog" Value="VerifyReadyDlg"
                   Condition="SERVERURL &lt;&gt; &quot;&quot; AND SERVERURL &lt;&gt; &quot;https://&quot;" />
        </Control>

        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="!(loc.WixUI_ButtonText_Cancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>

      </Dialog>
    </UI>
  </Fragment>

  <!-- ── Custom UI sequence ────────────────────────────────────────────────── -->
  <Fragment>
    <UI Id="WixUI_KungConnect">

      <!-- Pull in the common error/cancel dialogs -->
      <UIRef Id="WixUI_Common" />

      <!-- Font definitions required by the dialog controls above -->
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title"  FaceName="Tahoma" Size="9" Bold="yes" />
      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

      <!-- Reference the standard WixUI dialogs we need -->
      <DialogRef Id="WelcomeDlg" />
      <DialogRef Id="VerifyReadyDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ExitDialog" />

      <!-- Dialog navigation -->
      <Publish Dialog="WelcomeDlg"     Control="Next"   Event="NewDialog" Value="ServerUrlDlg" Condition="1" />
      <Publish Dialog="VerifyReadyDlg" Control="Back"   Event="NewDialog" Value="ServerUrlDlg" Condition="1" />
      <Publish Dialog="ExitDialog"     Control="Finish" Event="EndDialog"  Value="Return"       Order="999" Condition="1" />

    </UI>
  </Fragment>

</Wix>
