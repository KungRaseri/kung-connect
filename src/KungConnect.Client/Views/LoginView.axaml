<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KungConnect.Client.ViewModels"
             x:Class="KungConnect.Client.Views.LoginView"
             x:DataType="vm:LoginViewModel">

  <Grid RowDefinitions="*,Auto,*" HorizontalAlignment="Center" Width="360">

    <!-- Center card -->
    <StackPanel Grid.Row="1" Spacing="16">

      <TextBlock Text="KungConnect"
                 FontSize="28" FontWeight="Bold"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,8"/>

      <!-- Username -->
      <StackPanel Spacing="4">
        <TextBlock Text="Username"/>
        <TextBox Text="{Binding Username}"
                 Watermark="Enter username"
                 IsEnabled="{Binding !IsBusy}"/>
      </StackPanel>

      <!-- Password -->
      <StackPanel Spacing="4">
        <TextBlock Text="Password"/>
        <TextBox Text="{Binding Password}"
                 PasswordChar="•"
                 Watermark="Enter password"
                 IsEnabled="{Binding !IsBusy}"/>
      </StackPanel>

      <!-- Error message -->
      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="Red"
                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 TextWrapping="Wrap"/>

      <!-- Login button -->
      <Button Content="Sign In"
              Command="{Binding LoginCommand}"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              IsDefault="True"/>

      <!-- Busy indicator -->
      <ProgressBar IsVisible="{Binding IsBusy}"
                   IsIndeterminate="True"
                   Height="4"/>

    </StackPanel>
  </Grid>
</UserControl>
