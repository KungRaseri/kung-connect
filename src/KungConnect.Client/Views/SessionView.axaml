<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KungConnect.Client.ViewModels"
             x:Class="KungConnect.Client.Views.SessionView"
             x:DataType="vm:SessionViewModel">

  <DockPanel Background="Black" Focusable="True">

    <!-- Top bar -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto"
          Background="#CC1a1a1a" Height="40">

      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" Margin="12,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding RemoteAlias}" Foreground="White" FontWeight="SemiBold"/>
        <TextBlock Text=" — " Foreground="#888"/>
        <TextBlock Text="{Binding State}" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding StatusMessage}" Foreground="#4CAF50" FontSize="12" VerticalAlignment="Center"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336" FontSize="12" VerticalAlignment="Center"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
      </StackPanel>

      <Button Grid.Column="1" Content="✕ Disconnect"
              Command="{Binding DisconnectCommand}"
              Background="#C62828" Foreground="White"
              Margin="8,4" Padding="12,4"/>
    </Grid>

    <!-- Remote frame — filled via ReceiveFrame() in code-behind -->
    <Image Source="{Binding RemoteFrame}"
           Stretch="Uniform"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch"
           Name="RemoteImage"/>

  </DockPanel>
</UserControl>
