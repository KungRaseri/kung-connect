@page "/join"
@using Microsoft.AspNetCore.SignalR.Client
@inject IJSRuntime JS
@inject IConfiguration Config
@inject NavigationManager Nav
@inject KungConnect.Client.Web.Services.JoinSessionService JoinSvc
@implements IAsyncDisposable

<PageTitle>KungConnect — Join Session</PageTitle>

<div class="join-container">
    <div class="join-header">
        <h1 class="join-title">KungConnect</h1>
        <p class="join-subtitle">Remote support</p>
    </div>

    @if (_phase == Phase.EnterCode)
    {
        <div class="card">
            <p style="color:#cbd5e1;margin-bottom:1.25rem">
                Enter the 6-digit code your support agent gave you.
            </p>
            <div class="code-segments-row">
                @for (int i = 0; i < 6; i++)
                {
                    var idx = i;
                    <input class="code-segment @(_codeError ? "field-error" : "")"
                           maxlength="1" inputmode="numeric" pattern="\d"
                           value="@(_digits[idx])"
                           @oninput="e => OnDigitInput(idx, e)"
                           @onkeydown="e => OnDigitKeyDown(idx, e)" />
                    @if (i == 2) { <span class="code-sep">-</span> }
                }
            </div>
            @if (_codeError)
            {
                <p class="error" style="text-align:center;margin-top:.5rem">@_errorMessage</p>
            }
            <button class="btn-primary" style="width:100%;margin-top:1.5rem"
                    disabled="@(_digits.Any(d => string.IsNullOrEmpty(d)))"
                    @onclick="JoinAsync">
                Join Session
            </button>
        </div>
    }
    else if (_phase == Phase.Launching)
    {
        <div class="card" style="text-align:center">
            <div class="spinner" style="margin:0 auto 1.25rem"></div>
            <h3 style="color:#f1f5f9;margin:0 0 .5rem">
                @(_operatorJoined ? "Support agent connected!" : "Opening KungConnect\u2026")
            </h3>
            <p style="color:#94a3b8;line-height:1.6;margin-bottom:0">
                @if (_operatorJoined)
                {
                    <span>Your support agent is now connected.<br>Keep this tab open while your session is active.</span>
                }
                else
                {
                    <span>The KungConnect app should open automatically.<br>Keep this tab open while your session is active.</span>
                }
            </p>

            <div style="border-top:1px solid #334155;margin-top:1.5rem;padding-top:1.25rem">
                <p style="color:#64748b;font-size:.82rem;margin:0 0 .75rem">
                    App didn’t open? Download and install KungConnect first:
                </p>
                <div class="dl-row">
                    <button class="btn-ghost dl-btn" @onclick='() => DownloadAndShowInstructionsAsync("windows")'>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             style="width:.95rem;height:.95rem">
                            <rect x="2" y="3" width="20" height="14" rx="2"/>
                            <path stroke-linecap="round" d="M8 21h8M12 17v4"/>
                        </svg>
                        Windows
                    </button>
                    <button class="btn-ghost dl-btn" @onclick='() => DownloadAndShowInstructionsAsync("macos")'>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             style="width:.95rem;height:.95rem">
                            <circle cx="12" cy="8" r="4"/>
                            <path stroke-linecap="round" d="M6 20v-2a6 6 0 0112 0v2"/>
                        </svg>
                        macOS
                    </button>
                    <button class="btn-ghost dl-btn" @onclick='() => DownloadAndShowInstructionsAsync("linux")'>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             style="width:.95rem;height:.95rem">
                            <circle cx="12" cy="12" r="10"/>
                            <path stroke-linecap="round" d="M12 8v4m0 4h.01"/>
                        </svg>
                        Linux
                    </button>
                </div>
                <p style="color:#475569;font-size:.8rem;margin:.85rem 0 0">
                    After installing, come back and
                    <button class="kc-link" style="background:none;border:none;padding:0;font-size:.8rem;cursor:pointer"
                            @onclick="RetryLaunchAsync">click here to open again</button>.
                </p>
            </div>

            <button class="btn-ghost" style="margin-top:1.25rem;width:100%" @onclick="Reset">
                ← Enter a different code
            </button>
        </div>
    }
</div>

@code {
    private enum Phase { EnterCode, Launching, NotInstalled, Downloading }

    private record Platform(string Label, string Os);

    private Phase    _phase = Phase.EnterCode;
    private string[] _digits = new string[6];
    private bool     _codeError;
    private string   _errorMessage   = "";
    private string   _launchUri      = "";
    private string   _currentOs      = "windows";
    private string   _currentOsLabel = "Windows";
    private string   _downloadUrl    = "/downloads/windows";
    private List<string>   _installSteps   = [];
    private List<Platform> _otherPlatforms = [];
    private bool           _operatorJoined => JoinSvc.ConnectionState is "active" or "capturing";

    protected override void OnInitialized()
    {
        for (int i = 0; i < 6; i++) _digits[i] = "";
    }

    private async Task OnDigitInput(int idx, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        var val = new string(raw.Where(char.IsAsciiDigit).ToArray());
        if (val.Length > 1) val = val[^1..];
        _digits[idx] = val;
        _codeError = false;
        StateHasChanged();
        if (val.Length == 1 && idx < 5)
            await JS.InvokeVoidAsync("eval",
                string.Format("document.querySelectorAll('.code-segment')[{0}].focus()", idx + 1));
    }

    private async Task OnDigitKeyDown(int idx, KeyboardEventArgs e)
    {
        if (e.Key == "Backspace" && string.IsNullOrEmpty(_digits[idx]) && idx > 0)
            await JS.InvokeVoidAsync("eval",
                string.Format("document.querySelectorAll('.code-segment')[{0}].focus()", idx - 1));
        if (e.Key == "Enter" && _digits.All(d => !string.IsNullOrEmpty(d)))
            await JoinAsync();
    }

    private async Task JoinAsync()
    {
        var code = string.Concat(_digits);
        if (code.Length != 6 || !code.All(char.IsAsciiDigit))
        {
            _codeError = true;
            _errorMessage = "Enter all 6 digits.";
            return;
        }

        _currentOs = await JS.InvokeAsync<string>("kcDetectOs");
        ApplyOsInfo(_currentOs);

        var serverUrl = Config["ServerUrl"] ?? Nav.BaseUri.TrimEnd('/');
        _launchUri = $"kungconnect://join?code={code}&server={Uri.EscapeDataString(serverUrl)}";
        _phase = Phase.Launching;
        StateHasChanged();

        // Connect to the hub anonymously and register as waiting
        // This triggers JoinCodeCustomerReady on the operator's AdHoc page,
        // which fires kungconnect://adhoc to launch the operator's desktop client.
        await ConnectHubAndNotifyAsync(code, serverUrl);

        // Fire the URI to launch the customer's desktop client in parallel
        try { await JS.InvokeVoidAsync("kcLaunchUri", _launchUri); }
        catch { /* no registered handler is fine */ }
    }

    private async Task ConnectHubAndNotifyAsync(string code, string serverUrl)
    {
        try
        {
            // JoinSessionService manages the full WebRTC lifecycle (offer, answer, ICE, JPEG frames).
            // Subscribe to state changes so the UI re-renders when WebRTC progresses.
            JoinSvc.StateChanged += async () => await InvokeAsync(StateHasChanged);

            await JoinSvc.ConnectAsync(serverUrl, code);

            _operatorJoined = JoinSvc.ConnectionState is "active" or "connected" or "capturing";
        }
        catch
        {
            // Non-fatal: the operator side will just time out waiting
            // The customer's desktop client launch still works
        }
    }

    private async Task DownloadAndShowInstructionsAsync(string os)
    {
        ApplyOsInfo(os);
        _currentOs = os;
        await JS.InvokeVoidAsync("kcTriggerDownload", _downloadUrl);
        _phase = Phase.Downloading;
    }

    private async Task RetryLaunchAsync()
    {
        try { await JS.InvokeVoidAsync("kcLaunchUri", _launchUri); }
        catch { }
    }

    private void ApplyOsInfo(string os)
    {
        if (os == "macos")
        {
            _currentOsLabel = "macOS";
            _downloadUrl    = "/downloads/macos";
            _installSteps   =
            [
                "Open the downloaded <code>KungConnect.dmg</code> file.",
                "Drag KungConnect into your <strong>Applications</strong> folder.",
                "Open KungConnect from Applications (right-click → Open the first time to bypass Gatekeeper).",
                "Come back to this tab and click the button below."
            ];
            _otherPlatforms = [new("Windows", "windows"), new("Linux", "linux")];
        }
        else if (os == "linux")
        {
            _currentOsLabel = "Linux";
            _downloadUrl = "/downloads/linux";
            _installSteps   =
            [
                "Open a terminal in your Downloads folder.",
                "Run: <code>chmod +x KungConnect.AppImage</code>",
                "Run: <code>./KungConnect.AppImage --install</code> (registers the protocol handler)",
                "Come back to this tab and click the button below."
            ];
            _otherPlatforms = [new("Windows", "windows"), new("macOS", "macos")];
        }
        else // windows
        {
            _currentOsLabel = "Windows";
            _downloadUrl = "/downloads/windows";
            _installSteps   =
            [
                "Open the downloaded <code>KungConnect-Setup.exe</code>.",
                "Click <strong>Yes</strong> when Windows asks for permission.",
                "Follow the installer — it only takes about 30 seconds.",
                "Come back to this tab and click the button below."
            ];
            _otherPlatforms = [new("macOS", "macos"), new("Linux", "linux")];
        }
    }

    private void Reset()
    {
        _phase          = Phase.EnterCode;
        _digits         = new string[6];
        _codeError      = false;
        _errorMessage   = "";
        _launchUri      = "";
    }

    public async ValueTask DisposeAsync()
    {
        // JoinSessionService is scoped — Blazor's DI disposes it automatically,
        // but we unsubscribe from its event to avoid stale callbacks.
        JoinSvc.StateChanged -= async () => await InvokeAsync(StateHasChanged);

        // _hub is now owned by JoinSessionService; nothing to dispose here.
        await ValueTask.CompletedTask;
    }
}