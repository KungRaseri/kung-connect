@page "/dashboard"
@layout DashboardLayout
@inject AuthService Auth
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>KungConnect — Machines</PageTitle>

<div class="dash-page">
    <div class="dash-page-header">
        <h2>Machines</h2>
        <div style="display:flex;gap:.5rem;align-items:center">
            <button class="btn-ghost" @onclick="() => _showAddMachine = true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="width:1rem;height:1rem">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Add Machine
            </button>
            <button class="btn-primary" @onclick='() => Nav.NavigateTo("/dashboard/adhoc")'>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="width:1rem;height:1rem">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                New Ad Hoc Session
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="dash-empty">Loading machines…</div>
    }
    else if (_machines.Count == 0)
    {
        <div class="dash-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <p>No machines connected yet.</p>
            <p class="hint">
                Install the KungConnect Agent on any machine, set <code>Agent__ServerUrl</code> to this server,
                and it will appear here automatically.
            </p>
        </div>
    }
    else
    {
        <div class="machine-grid">
            @foreach (var m in _machines)
            {
                <div class="machine-card @(m.Online ? "online" : m.Uninstalled ? "uninstalled" : "offline")" style="cursor:pointer"
                     @onclick='() => Nav.NavigateTo($"/dashboard/machines/{m.Id}")'>
                    <div class="machine-card-header">
                        <span class="machine-status-dot"></span>
                        <span class="machine-name">@m.Alias</span>
                        <span class="machine-os">@m.OsType</span>
                    </div>
                    <p class="machine-host">@m.Hostname</p>
                    @if (m.HasUpdate)
                    {
                        <p style="margin:.35rem 0 0;font-size:.75rem;color:#facc15;display:flex;align-items:center;gap:.3rem">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                 style="width:.85rem;height:.85rem;flex-shrink:0">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7 7 7M12 3v13M5 21h14"/>
                            </svg>
                            v@m.UpdateAvailable available
                        </p>
                    }
                    <p class="machine-seen">Last seen @m.LastSeenRelative</p>
                    @if (m.Online)
                    {
                        var launchUri = $"kungconnect://session?server={Uri.EscapeDataString(Nav.BaseUri.TrimEnd('/'))}" +
                                        $"&machine={m.Id}&token={Uri.EscapeDataString(Auth.AccessToken ?? "")}";
                        <ConnectButton LaunchUri="@launchUri" />
                    }
                    else
                    {
                        <button class="btn-primary" style="width:100%;margin-top:1rem" disabled>
                            @(m.Uninstalled ? "Not Installed" : "Offline")
                        </button>
                    }
                </div>
            }
        </div>
    }

    @* ── Download Agent ── always visible so you can add more machines ──── *@
    <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid #1e293b">
        <p style="color:#64748b;font-size:.8rem;margin:0 0 .6rem;text-transform:uppercase;letter-spacing:.06em">Download Agent</p>
        <div style="display:flex;gap:.5rem;flex-wrap:wrap">
            <a class="btn-ghost dl-btn" href="/downloads/agent/windows" target="_blank">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:1rem;height:1rem">
                    <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
                </svg>
                Windows
            </a>
            <a class="btn-ghost dl-btn" href="/downloads/agent/macos" target="_blank">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:1rem;height:1rem">
                    <path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/>
                </svg>
                macOS
            </a>
            <a class="btn-ghost dl-btn" href="/downloads/agent/linux" target="_blank">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:1rem;height:1rem">
                    <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.16-.16.36-.12.508.213.04.375-.04.466-.159.14.205.33.4.515.562.528.474 1.134.852 1.737 1.098.523.207 1.134.33 1.753.37.71.05 1.44-.03 2.1-.22.66-.18 1.23-.5 1.74-.98.51-.49.88-1.14 1.04-1.87.14-.67.1-1.36-.11-2.01-.18-.54-.5-1.04-.93-1.46.2-.33.38-.65.5-1 .28-.87.39-1.8.3-2.76-.09-1.04-.38-2.05-.8-2.98.84-1.71 1.29-3.54.88-5.34C19.84 2.65 18.15.75 16.22.16 15.01-.2 13.74-.01 12.504 0z"/>
                </svg>
                Linux (x64)
            </a>
            <a class="btn-ghost dl-btn" href="/downloads/agent/linux-arm64" target="_blank">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:1rem;height:1rem">
                    <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.16-.16.36-.12.508.213.04.375-.04.466-.159.14.205.33.4.515.562.528.474 1.134.852 1.737 1.098.523.207 1.134.33 1.753.37.71.05 1.44-.03 2.1-.22.66-.18 1.23-.5 1.74-.98.51-.49.88-1.14 1.04-1.87.14-.67.1-1.36-.11-2.01-.18-.54-.5-1.04-.93-1.46.2-.33.38-.65.5-1 .28-.87.39-1.8.3-2.76-.09-1.04-.38-2.05-.8-2.98.84-1.71 1.29-3.54.88-5.34C19.84 2.65 18.15.75 16.22.16 15.01-.2 13.74-.01 12.504 0z"/>
                </svg>
                Linux (ARM64)
            </a>
        </div>
    </div>
</div>

@* ── Add Machine modal ──────────────────────────────────────────────────── *@
@if (_showAddMachine)
{
    <div @onclick="CloseAddMachine"
         style="position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:100;display:flex;align-items:center;justify-content:center">
        <div @onclick:stopPropagation
             style="background:#1e293b;border:1px solid #334155;border-radius:12px;padding:2rem;width:min(520px,92vw);max-height:90vh;overflow-y:auto">

            @if (_provisionedConfig is null)
            {
                <h3 style="margin:0 0 .5rem;color:#f1f5f9">Add Machine</h3>
                <p style="color:#94a3b8;margin:0 0 1.5rem;font-size:.9rem">
                    Give the machine a name. You'll get a config snippet to paste into the agent on that machine.
                </p>

                <label class="field-label">Machine Name</label>
                <input class="field-input" @bind="_newAlias" @bind:event="oninput"
                       placeholder="e.g. Office PC, Server-01"
                       disabled="@_provisioning"
                       style="width:100%;box-sizing:border-box;margin-top:.35rem"/>

                @if (_provisionError is not null)
                {
                    <p class="error" style="margin-top:.75rem">@_provisionError</p>
                }

                <div style="display:flex;gap:.5rem;margin-top:1.25rem">
                    <button class="btn-primary"
                            @onclick="ProvisionMachineAsync"
                            disabled="@(_provisioning || string.IsNullOrWhiteSpace(_newAlias))">
                        @(_provisioning ? "Generating…" : "Generate Config")
                    </button>
                    <button class="btn-ghost" @onclick="CloseAddMachine">Cancel</button>
                </div>
            }
            else
            {
                <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem">
                    <span style="color:#4ade80;font-size:1.4rem">✓</span>
                    <h3 style="margin:0;color:#f1f5f9">Machine Added</h3>
                </div>
                <p style="color:#94a3b8;margin:0 0 1rem;font-size:.9rem">
                    Copy this into <code>appsettings.json</code> in the same folder as the agent binary,
                    then run <code>KungConnect.Agent</code> on that machine.
                </p>
                <pre style="background:#0f172a;border:1px solid #334155;border-radius:8px;padding:1rem;overflow-x:auto;font-size:.8rem;color:#e2e8f0;white-space:pre;margin:0">@_provisionedConfig</pre>
                <div style="display:flex;gap:.5rem;margin-top:1rem">
                    <button class="btn-ghost"
                            @onclick='() => JS.InvokeVoidAsync("navigator.clipboard.writeText", _provisionedConfig)'>
                        📋 Copy
                    </button>
                    <button class="btn-primary"
                            @onclick="() => { CloseAddMachine(); _ = LoadMachinesAsync(); }">
                        Done
                    </button>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<MachineViewModel> _machines = [];
    private bool _loading = true;
    private string _serverOrigin => new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority);

    // ── Add Machine modal ────────────────────────────────────────────────────
    private bool    _showAddMachine;
    private string  _newAlias        = "";
    private bool    _provisioning;
    private string? _provisionError;
    private string? _provisionedConfig;

    private void CloseAddMachine()
    {
        _showAddMachine    = false;
        _newAlias          = "";
        _provisionError    = null;
        _provisionedConfig = null;
    }

    private async Task ProvisionMachineAsync()
    {
        _provisionError = null;
        _provisioning   = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("/api/machines/provision", new { Alias = _newAlias });
            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadFromJsonAsync<ApiError>();
                _provisionError = err?.Error ?? $"Server returned {(int)resp.StatusCode}";
                return;
            }
            var result = await resp.Content.ReadFromJsonAsync<ProvisionResult>();
            _provisionedConfig = result?.ConfigSnippet;
        }
        catch (Exception ex) { _provisionError = ex.Message; }
        finally { _provisioning = false; }
    }

    private sealed record ProvisionResult(Guid MachineId, string Secret, string ConfigSnippet);
    private sealed record ApiError(string? Error);

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        Auth.ApplyAuthHeader();
        await LoadMachinesAsync();
    }

    private async Task LoadMachinesAsync()
    {
        _loading = true;
        try
        {
            var dtos = await Http.GetFromJsonAsync<MachineDto[]>("/api/machines") ?? [];
            _machines = dtos.Select(d => new MachineViewModel(d)).ToList();
        }
        catch { /* handled by empty state */ }
        finally { _loading = false; }
    }

    // ── View models ─────────────────────────────────────────────────────────

    private sealed record MachineDto(
        Guid Id, string Alias, string Hostname,
        string OsType, string Status, string AgentVersion,
        DateTimeOffset LastSeen, string? UpdateAvailable = null);

    private sealed class MachineViewModel(MachineDto d)
    {
        public Guid   Id       => d.Id;
        public string Alias    => d.Alias;
        public string Hostname => d.Hostname;
        public string OsType   => d.OsType;
        public bool   Online       => d.Status == "Online";
        public bool   Uninstalled  => d.Status == "Uninstalled";
        public bool   HasUpdate    => !string.IsNullOrEmpty(d.UpdateAvailable);
        public string? UpdateAvailable => d.UpdateAvailable;
        public string LastSeenRelative
        {
            get
            {
                var diff = DateTimeOffset.UtcNow - d.LastSeen;
                return diff.TotalSeconds < 90  ? "just now"
                     : diff.TotalMinutes < 60  ? $"{(int)diff.TotalMinutes}m ago"
                     : diff.TotalHours   < 24  ? $"{(int)diff.TotalHours}h ago"
                     : $"{(int)diff.TotalDays}d ago";
            }
        }
    }
}
