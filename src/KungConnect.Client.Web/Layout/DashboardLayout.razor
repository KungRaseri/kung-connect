@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@implements IAsyncDisposable

@if (!_checked)
{
    <!-- Auth check in progress — show nothing to avoid flash -->
    <div class="dash-splash"></div>
}
else
{
    <div class="dash-shell">
        <!-- Sidebar -->
        <nav class="dash-sidebar">
            <div class="dash-logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <span>KungConnect</span>
            </div>

            <ul class="dash-nav">
                <li>
                    <NavLink href="/dashboard" Match="NavLinkMatch.All">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/>
                        </svg>
                        Machines
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/dashboard/adhoc">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 4v16m8-8H4"/>
                        </svg>
                        Ad Hoc Session
                    </NavLink>
                </li>
            </ul>

            <div class="dash-user">
                <span class="dash-username">@Auth.Username</span>
                <button class="dash-logout" @onclick="LogoutAsync" title="Sign out">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1"/>
                    </svg>
                </button>
            </div>
        </nav>

        <!-- Main content -->
        <main class="dash-main">
            @Body
        </main>
    </div>
}

@code {
    private bool _checked;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!Auth.IsAuthenticated)
            Nav.NavigateTo("/login?returnUrl=" + Uri.EscapeDataString(Nav.Uri), replace: true);
        else
        {
            Auth.ApplyAuthHeader();
            _checked = true;
        }
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", replace: true);
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
