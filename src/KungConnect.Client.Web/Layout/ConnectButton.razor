@inject IJSRuntime JS
@inject NavigationManager Nav

@* ── Connect button with install-prompt fallback ──────────────────────── *@
<button class="btn-primary" @onclick="HandleClickAsync" disabled="@_busy">
    @if (_busy)
    {
        <span style="display:inline-block;width:.9rem;height:.9rem;border:2px solid rgba(255,255,255,.3);
                     border-top-color:#fff;border-radius:50%;animation:kc-spin .7s linear infinite;
                     margin-right:.4rem;vertical-align:middle"></span>
        <span>Connecting…</span>
    }
    else
    {
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             style="width:1rem;height:1rem">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <span>Connect</span>
    }
</button>

@if (_showInstallModal)
{
    <div @onclick="() => _showInstallModal = false"
         style="position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:200;display:flex;align-items:center;justify-content:center">
        <div @onclick:stopPropagation
             style="background:#1e293b;border:1px solid #334155;border-radius:12px;padding:2rem;width:min(440px,92vw)">

            <h3 style="margin:0 0 .5rem;color:#f1f5f9">KungConnect Client Not Found</h3>
            <p style="color:#94a3b8;font-size:.9rem;margin:0 0 1.25rem;line-height:1.5">
                The KungConnect desktop client needs to be installed on <strong style="color:#e2e8f0">this machine</strong>
                to start a remote session. Download and run the installer, then come back here.
            </p>

            @if (!_downloaded)
            {
                <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.25rem">
                    @if (_os == "windows")
                    {
                        <a href="/downloads/windows" target="_blank" class="btn-primary" style="text-decoration:none"
                           @onclick="OnDownloadClicked">
                            ⬇ Download for Windows
                        </a>
                    }
                    else if (_os == "macos")
                    {
                        <a href="/downloads/macos" target="_blank" class="btn-primary" style="text-decoration:none"
                           @onclick="OnDownloadClicked">
                            ⬇ Download for macOS
                        </a>
                    }
                    else
                    {
                        <a href="/downloads/linux" target="_blank" class="btn-primary" style="text-decoration:none"
                           @onclick="OnDownloadClicked">
                            ⬇ Download for Linux
                        </a>
                    }
                </div>
            }
            else
            {
                <div style="background:#0f2b1a;border:1px solid #16a34a;border-radius:.5rem;
                            padding:.65rem 1rem;margin-bottom:1.25rem;font-size:.875rem;color:#4ade80">
                    ✓ Installer downloaded. Run it, then click <strong>Launch Now</strong>.
                </div>
                <div style="display:flex;gap:.5rem;margin-bottom:1.25rem">
                    <button class="btn-primary" @onclick="RetryLaunchAsync">
                        🚀 Launch Now
                    </button>
                    <button class="btn-ghost" style="font-size:.8rem" @onclick="OnDownloadClicked">
                        Download again
                    </button>
                </div>
            }

            <p style="color:#64748b;font-size:.8rem;margin:0 0 1rem">
                Already installed but nothing opened?
                <button @onclick="RetryLaunchAsync"
                        style="background:none;border:none;color:#60a5fa;cursor:pointer;font-size:.8rem;padding:0;text-decoration:underline">
                    Try again
                </button>
            </p>

            <button class="btn-ghost" @onclick="() => _showInstallModal = false">Cancel</button>
        </div>
    </div>
}

<style>
    @@keyframes kc-spin { to { transform: rotate(360deg); } }
</style>

@code {
    /// <summary>The full kungconnect:// URI to launch.</summary>
    [Parameter, EditorRequired] public string LaunchUri { get; set; } = "";

    private bool   _busy;
    private bool   _showInstallModal;
    private bool   _downloaded;
    private string _os = "windows";

    protected override async Task OnInitializedAsync()
    {
        _os = await JS.InvokeAsync<string>("kcDetectOs");
    }

    private async Task HandleClickAsync()
    {
        _busy = true;
        _showInstallModal = false;
        StateHasChanged();

        var opened = await JS.InvokeAsync<bool>("kcTryLaunch", LaunchUri);

        _busy = false;
        if (!opened)
        {
            _downloaded = false;
            _showInstallModal = true;
        }
        StateHasChanged();
    }

    private void OnDownloadClicked()
    {
        _downloaded = true;
        StateHasChanged();
    }

    private async Task RetryLaunchAsync()
    {
        _showInstallModal = false;
        _busy = true;
        StateHasChanged();

        await JS.InvokeVoidAsync("kcMarkInstalledAndLaunch", LaunchUri);

        await Task.Delay(2000);
        _busy = false;
        StateHasChanged();
    }
}
