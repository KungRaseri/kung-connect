<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFrameworks>net9.0-windows;net9.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>dotnet-KungConnect.Agent-19bad793-c5ea-4b27-bd03-352669f23b87</UserSecretsId>
  </PropertyGroup>

  <!-- Windows: run windowless with WinForms system tray -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'net9.0-windows'">
    <OutputType>WinExe</OutputType>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <!-- Linux / macOS: run as a headless background service -->
  <PropertyGroup Condition="'$(TargetFramework)' != 'net9.0-windows'">
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" Version="9.0.3" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.0.13" />
    <PackageReference Include="SIPSorcery" Version="10.0.3" />
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\KungConnect.Shared\KungConnect.Shared.csproj" />
  </ItemGroup>
</Project>
